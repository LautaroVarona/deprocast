DATABASE_URL="file:./prisma/dev.db"

# Local: ruta al JSON de la cuenta de servicio
GOOGLE_APPLICATION_CREDENTIALS="./local-transcriber-498907-dc909fc4d9b9.json"
# Vercel: pegá el JSON completo en una sola línea
# GCP_SPEECH_CREDENTIALS_JSON='{"type":"service_account",...}'
GOOGLE_CLOUD_PROJECT="local-transcriber-498907"
GCP_SPEECH_LOCATION="us-central1"
GCP_SPEECH_MODEL="chirp_2"
GCP_SPEECH_LANGUAGE="es-ES"
GCP_SPEECH_CHUNK_SECONDS="50"
GCP_SPEECH_SYNC_MAX_SECONDS="55"
GCP_SPEECH_CHUNK_DELAY_MS="400"

# Vertex AI (purificador + portal de visión en /ingesta — proyecto varonapi)
GOOGLE_CLOUD_PROJECT2="varonapi-496707"
GOOGLE_APPLICATION_CREDENTIALS2="./varonapi-496707-85d9ae6468bd.json"
# Vercel: pegá el JSON completo en una sola línea
# VERTEX_CREDENTIALS_JSON='{"type":"service_account",...}'
VERTEX_LOCATION="europe-west1"
VERTEX_MODEL="gemini-2.5-flash"
VERTEX_REQUEST_DELAY_MS="500"

# Opcional: raíz personalizada para datos en disco (útil en staging)
# DEPROCAST_DATA_ROOT="/tmp/deprocast"

# Opcional: rutas personalizadas si no usás los binarios de npm
# FFMPEG_PATH="C:/ruta/a/ffmpeg.exe"
# FFPROBE_PATH="C:/ruta/a/ffprobe.exe"

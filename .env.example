DATABASE_URL="file:./prisma/dev.db"

# Deepgram Speech-to-Text (transcripción de audio)
DEEPGRAM_API_KEY="tu-api-key-de-deepgram"
DEEPGRAM_MODEL="nova-3"
DEEPGRAM_LANGUAGE="es"
DEEPGRAM_CHUNK_SECONDS="50"
DEEPGRAM_SYNC_MAX_SECONDS="55"
DEEPGRAM_CHUNK_DELAY_MS="400"

# Cohere — LLM, visión, embeddings y rerank
COHERE_API_KEY="tu-api-key-de-cohere"

# Cerebro principal (RAG, chat, purifier, KG, enciclopedia…)
COHERE_MODEL="command-r-plus-08-2024"

# Tareas más livianas / alto volumen (cleanup STT, esencias, eventos)
COHERE_MODEL_FAST="command-r-08-2024"

# OCR multimodal (ingesta visión + cuadernos)
COHERE_VISION_MODEL="command-a-vision-07-2025"

# Mnemosyne — memoria semántica
COHERE_EMBED_MODEL="embed-v4.0"
COHERE_RERANK_MODEL="rerank-v3.5"
COHERE_MAX_OUTPUT_TOKENS="2048"

# Throttling entre llamadas LLM (purifier hace varias seguidas)
COHERE_REQUEST_DELAY_MS="500"

# Opcional: modelo unificado visión+agente (más caro)
# COHERE_MODEL_AGENT="command-a-plus-05-2026"

# Opcional: raíz personalizada para datos en disco (útil en staging)
# DEPROCAST_DATA_ROOT="/tmp/deprocast"

# Opcional: rutas personalizadas si no usás los binarios de npm
# FFMPEG_PATH="C:/ruta/a/ffmpeg.exe"
# FFPROBE_PATH="C:/ruta/a/ffprobe.exe"

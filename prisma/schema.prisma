generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Status values: PENDING | PROCESSING | COMPLETED | ERROR
model AudioAsset {
  id                String   @id @default(uuid())
  filename          String
  fileUrl           String
  durationMs        Int?
  originalCreatedAt DateTime
  status            String   @default("PENDING")
  partialText       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transcript Transcript?

  @@index([status])
}

model Transcript {
  id         String   @id @default(uuid())
  assetId    String   @unique
  rawText    String
  confidence Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  asset        AudioAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  parentChunks ParentChunk[]
}

model ParentChunk {
  id           String @id @default(uuid())
  transcriptId String
  content      String
  startTimeMs  Int
  endTimeMs    Int
  summary      String

  transcript Transcript          @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  children   ChildChunk[]
  entities   ParentChunkEntity[]
  tags       ParentChunkTag[]

  @@index([transcriptId])
}

model ChildChunk {
  id       String @id @default(uuid())
  parentId String
  content  String

  parent ParentChunk @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
}

model Entity {
  id   String @id @default(uuid())
  name String @unique
  type String

  parentChunks ParentChunkEntity[]
}

model Tag {
  id   String @id @default(uuid())
  name String @unique

  parentChunks ParentChunkTag[]
}

model ParentChunkEntity {
  parentChunkId String
  entityId      String

  parentChunk ParentChunk @relation(fields: [parentChunkId], references: [id], onDelete: Cascade)
  entity      Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([parentChunkId, entityId])
}

model ParentChunkTag {
  parentChunkId String
  tagId         String

  parentChunk ParentChunk @relation(fields: [parentChunkId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([parentChunkId, tagId])
}

model KgNode {
  id          String   @id @default(uuid())
  primaryName String
  type        String
  aliases     Json
  metadata    Json
  confidence  Float    @default(0.6)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outgoingEdges KgEdge[]    @relation("KgEdgeSource")
  incomingEdges KgEdge[]    @relation("KgEdgeTarget")
  mentions      KgMention[]

  @@unique([primaryName, type])
  @@index([type])
  @@index([primaryName])
}

model KgEdge {
  id           String   @id @default(uuid())
  sourceNodeId String
  targetNodeId String
  relationType String
  context      String
  weight       Int?
  confidence   Float    @default(0.6)
  metadata     Json
  createdAt    DateTime @default(now())

  sourceNode KgNode @relation("KgEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode KgNode @relation("KgEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, relationType])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([relationType])
}

model KgMention {
  id          String   @id @default(uuid())
  nodeId      String
  sourceType  String
  sourceId    String
  fragment    String
  offsetStart Int?
  offsetEnd   Int?
  confidence  Float    @default(0.6)
  metadata    Json
  createdAt   DateTime @default(now())

  node KgNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([sourceType, sourceId])
  @@index([nodeId])
}

// Registro de fuentes ingeridas para ingesta incremental basada en hash.
model KgSource {
  id             String   @id @default(uuid())
  sourceType     String
  sourceId       String
  contentHash    String
  nodeCount      Int      @default(0)
  edgeCount      Int      @default(0)
  mentionCount   Int      @default(0)
  metadata       Json
  lastIngestedAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([sourceType])
}

model VibeCalibrationSession {
  id          String   @id @default(uuid())
  config      Json
  startedAt   DateTime @default(now())
  completedAt DateTime?
  votes       VibeCalibrationVote[]
}

model VibeCalibrationVote {
  id         String   @id @default(uuid())
  sessionId  String
  cardId     String
  cardSource String
  sourceRef  String?
  weight     Int
  metadata   Json
  votedAt    DateTime @default(now())

  session VibeCalibrationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([cardId])
}

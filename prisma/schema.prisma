generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Status values: PENDING | PROCESSING | COMPLETED | ERROR
model AudioAsset {
  id                String   @id @default(uuid())
  filename          String
  fileUrl           String
  durationMs        Int?
  originalCreatedAt DateTime
  status            String   @default("PENDING")
  partialText       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transcript Transcript?

  @@index([status])
}

model Transcript {
  id         String   @id @default(uuid())
  assetId    String   @unique
  rawText    String
  confidence Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  asset        AudioAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  parentChunks ParentChunk[]
}

model ParentChunk {
  id           String @id @default(uuid())
  transcriptId String
  content      String
  startTimeMs  Int
  endTimeMs    Int
  summary      String

  transcript Transcript          @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  children   ChildChunk[]
  entities   ParentChunkEntity[]
  tags       ParentChunkTag[]

  @@index([transcriptId])
}

model ChildChunk {
  id       String @id @default(uuid())
  parentId String
  content  String

  parent ParentChunk @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
}

model Entity {
  id   String @id @default(uuid())
  name String @unique
  type String

  parentChunks ParentChunkEntity[]
}

model Tag {
  id   String @id @default(uuid())
  name String @unique

  parentChunks ParentChunkTag[]
}

model ParentChunkEntity {
  parentChunkId String
  entityId      String

  parentChunk ParentChunk @relation(fields: [parentChunkId], references: [id], onDelete: Cascade)
  entity      Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([parentChunkId, entityId])
}

model ParentChunkTag {
  parentChunkId String
  tagId         String

  parentChunk ParentChunk @relation(fields: [parentChunkId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([parentChunkId, tagId])
}

model KgNode {
  id          String   @id @default(uuid())
  primaryName String
  type        String
  aliases     Json
  metadata    Json
  confidence  Float    @default(0.6)
  reconocido  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outgoingEdges KgEdge[]    @relation("KgEdgeSource")
  incomingEdges KgEdge[]    @relation("KgEdgeTarget")
  mentions      KgMention[]

  @@unique([primaryName, type])
  @@index([type])
  @@index([primaryName])
  @@index([reconocido])
}

// Perfil singleton del Observador — Centro de Mando /yo
model OperatorProfile {
  id                String   @id @default("operator")
  displayName       String   @default("Lautaro")
  operationalStatus String   @default("OPERATIVO")
  energyLevel       Int      @default(6)
  calibration       Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model KgEdge {
  id           String   @id @default(uuid())
  sourceNodeId String
  targetNodeId String
  relationType String
  context      String
  weight       Int?
  reconocido   Boolean  @default(false)
  confidence   Float    @default(0.6)
  metadata     Json
  createdAt    DateTime @default(now())

  sourceNode KgNode @relation("KgEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode KgNode @relation("KgEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, relationType])
  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([relationType])
  @@index([reconocido])
}

// Linaje ambiental de captura — metadata contextual y actores tipados.
model OriginAttribution {
  id              String   @id @default(uuid())
  channel         String
  timestampExacto DateTime
  diaSemana       String
  locationName    String?
  actors          Json
  createdAt       DateTime @default(now())

  quantomos Quantomo[]

  @@index([channel])
  @@index([timestampExacto])
}

// Partícula mínima de conocimiento (fragmento atómico de ingesta).
model Quantomo {
  id                  String   @id @default(uuid())
  titleSugerido       String
  content             String
  tagsSemanticos      Json     @default("[]")
  universo            String
  createdAt           DateTime @default(now())
  originAttributionId String

  originAttribution OriginAttribution @relation(fields: [originAttributionId], references: [id], onDelete: Cascade)

  @@index([universo])
  @@index([originAttributionId])
  @@index([createdAt])
}

model KgMention {
  id          String   @id @default(uuid())
  nodeId      String
  sourceType  String
  sourceId    String
  fragment    String
  offsetStart Int?
  offsetEnd   Int?
  confidence  Float    @default(0.6)
  metadata    Json
  createdAt   DateTime @default(now())

  node KgNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([sourceType, sourceId])
  @@index([nodeId])
}

// Registro de fuentes ingeridas para ingesta incremental basada en hash.
model KgSource {
  id             String   @id @default(uuid())
  sourceType     String
  sourceId       String
  contentHash    String
  nodeCount      Int      @default(0)
  edgeCount      Int      @default(0)
  mentionCount   Int      @default(0)
  metadata       Json
  lastIngestedAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([sourceType])
}

model VibeCalibrationSession {
  id          String   @id @default(uuid())
  config      Json
  startedAt   DateTime @default(now())
  completedAt DateTime?
  votes       VibeCalibrationVote[]
}

model VibeCalibrationVote {
  id         String   @id @default(uuid())
  sessionId  String
  cardId     String
  cardSource String
  sourceRef  String?
  weight     Int
  metadata   Json
  votedAt    DateTime @default(now())

  session VibeCalibrationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([cardId])
}

// Cola de validación de proyectos (incubadora / bandeja de entrada).
model ProjectProposal {
  id                 String    @id @default(uuid())
  title              String
  status             String    @default("pending")
  originContext      String
  originType         String
  originRef          String?

  description        String    @default("")
  suggestedCampoSlug String?
  suggestedTipo      String?

  mvp                String?
  firstStep          String?
  priorityReason     String?

  sourcePayload      Json?

  activatedProjectId String?
  activatedAt        DateTime?
  archivedAt         DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Incubador conversacional de proyectos (/proyectos/nuevo).
model ProjectIncubationSession {
  id              String   @id @default(uuid())
  status          String   @default("active")
  messages        Json
  extractionState Json
  projectId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([updatedAt])
}

// Módulo Chat Exocórtex — sesiones, mensajes y relaciones de contexto (@mentions).
model ChatSession {
  id           String        @id @default(uuid())
  title        String        @default("Nueva conversación")
  universeSlug String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]

  @@index([updatedAt])
  @@index([universeSlug, updatedAt])
}

model ChatMessage {
  id              String               @id @default(uuid())
  sessionId       String
  role            String
  content         String
  contentDisplay  String?
  injectedContext String?
  model           String?
  tokenCount      Int?
  createdAt       DateTime             @default(now())

  session           ChatSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contextRelations  ChatContextRelation[]

  @@index([sessionId, createdAt])
}

model ChatContextRelation {
  id          String   @id @default(uuid())
  messageId   String
  entityType  String
  entityId    String
  entityLabel String
  createdAt   DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([entityType, entityId, createdAt])
}

// Tareas pendientes — Listador, validación y calibración 1–12.
model PendingTask {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  status             String    @default("suggested")
  source             String
  sourceRef          String?
  targetDay          DateTime
  weight             Int?
  bloque             String?
  projectId          String?
  reviewId           String?
  universeSlug       String?
  listadorConfidence Float?
  recognizedAt       DateTime?
  calibratedAt       DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  assaults LudusAssaultSession[]

  @@index([status, targetDay])
  @@index([source, sourceRef])
  @@index([weight, targetDay])
  @@index([universeSlug, status, targetDay])
}

// Planos de proyección — Universos de Babel (Babel = raíz).
model Universe {
  id             String   @id @default(uuid())
  slug           String   @unique
  label          String
  description    String   @default("")
  trenchesWeight Int?
  isRoot         Boolean  @default(false)
  discoveredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  records      BabelRecord[]
  projections  UniverseProjection[] @relation("ProjectionTarget")
}

// Proyección manual: enlaza materia de otro universo sin mover el registro original.
model UniverseProjection {
  id          String   @id @default(uuid())
  targetSlug  String
  kind        String
  physicalRef String
  sourceSlug  String
  scope       String?
  scopeRef    String?
  importedAt  DateTime @default(now())

  target Universe @relation("ProjectionTarget", fields: [targetSlug], references: [slug])

  @@unique([targetSlug, kind, physicalRef])
  @@index([targetSlug])
  @@index([sourceSlug])
}

// Registro canónico raíz — índice unificado de toda materia prima.
model BabelRecord {
  id             String   @id @default(uuid())
  kind           String
  physicalRef    String
  contentPreview String   @default("")
  occurredAt     DateTime
  contextSeal    String
  campoSlug      String?
  channel        String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  universe Universe @relation(fields: [contextSeal], references: [slug])

  @@index([contextSeal, occurredAt])
  @@index([kind, physicalRef])
}

// Event log unificado — cruza Chat, Diario, Salud y Proyectos.
// blockKind: IMMUTABLE | ROUTINE | SUGGESTION
// executionStatus: scheduled | confirmed_day | skipped | executed | coagulated
// ecosystemArea: legal | salud | finanzas | tecnologia | arte | meta
model ContextEvent {
  id              String    @id @default(uuid())
  occurredAt      DateTime
  source          String
  sourceRef       String?
  content         String
  structuredData  Json
  pillar          String
  status          String    @default("proposed")
  correlationId   String?
  blockKind       String    @default("ROUTINE")
  actionCost      Int?
  executionStatus String    @default("scheduled")
  ecosystemArea   String?
  endsAt          DateTime?
  durationMin     Int?
  createdAt       DateTime  @default(now())

  links         ContextEventLink[]
  healthRecords HealthRecord[]

  @@index([source, sourceRef])
  @@index([status, occurredAt])
  @@index([pillar, occurredAt])
  @@index([correlationId])
  @@index([blockKind, occurredAt])
  @@index([ecosystemArea, occurredAt])
  @@index([executionStatus, occurredAt])
}

model ContextEventLink {
  id          String   @id @default(uuid())
  eventId     String
  entityType  String
  entityId    String
  entityLabel String?
  linkRole    String   @default("primary")
  createdAt   DateTime @default(now())

  event ContextEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([entityType, entityId])
}

// Telemetría de salud estructurada (4 pilares).
model HealthRecord {
  id            String   @id @default(uuid())
  pillar        String
  occurredAt    DateTime
  summary       String
  metrics       Json
  sourceEventId String?
  createdAt     DateTime @default(now())

  sourceEvent ContextEvent? @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)
  nutritionEntries NutritionEntry[] @relation("HealthRecordNutritionEntry")
  trainingSessions TrainingSession[] @relation("HealthRecordTrainingSession")

  @@index([pillar, occurredAt])
  @@index([sourceEventId])
}

// Salud v2 — registros dedicados para alimentación y entrenamiento.
model NutritionEntry {
  id            String   @id @default(uuid())
  summary       String
  sourceChannel String
  sourceRaw     String?
  occurredAt    DateTime
  parsedBy      String
  confidence    Float?
  totalCalories Float?
  totalProtein  Float?
  totalCarbs    Float?
  totalFat      Float?
  notes         String?
  healthRecordId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items        NutritionItem[]
  healthRecord HealthRecord? @relation("HealthRecordNutritionEntry", fields: [healthRecordId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([sourceChannel, occurredAt])
  @@index([healthRecordId])
}

model NutritionItem {
  id         String   @id @default(uuid())
  entryId    String
  name       String
  quantity   String?
  grams      Float?
  calories   Float?
  protein    Float?
  carbs      Float?
  fat        Float?
  createdAt  DateTime @default(now())

  entry NutritionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model TrainingSession {
  id             String   @id @default(uuid())
  summary        String
  sourceChannel  String
  sourceRaw      String?
  occurredAt     DateTime
  parsedBy       String
  confidence     Float?
  durationMin    Int?
  totalVolumeKg  Float?
  intensity      String?
  notes          String?
  healthRecordId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sets        TrainingSet[]
  healthRecord HealthRecord? @relation("HealthRecordTrainingSession", fields: [healthRecordId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([sourceChannel, occurredAt])
  @@index([healthRecordId])
}

model TrainingSet {
  id         String   @id @default(uuid())
  sessionId  String
  exercise   String
  series     Int?
  reps       Int?
  weightKg   Float?
  durationMin Int?
  distanceKm Float?
  intensity  String?
  createdAt  DateTime @default(now())

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// Módulo Cuadernos — entidades físicas antes del procesamiento de texto.
// Page status: PENDING | PROCESSING | COMPLETED | ERROR
model Notebook {
  id              String         @id @default(uuid())
  title           String
  description     String?
  coverHue        Int            @default(220)
  kind            String         @default("cuaderno")
  authorPersonaId String?
  metatags        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  pages           NotebookPage[]

  @@index([createdAt])
  @@index([authorPersonaId])
}

model NotebookPage {
  id               String    @id @default(uuid())
  notebookId       String
  pageNumber       Int
  filename         String
  imagePath        String
  mimeType         String
  status           String    @default("PENDING")
  semanticVector   String?
  structuralVector Json?
  quanta           Json?
  processedAt      DateTime?
  corpusCaptureId  String?
  pageMetatags     Json?
  enrichments      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@unique([notebookId, pageNumber])
  @@index([notebookId])
  @@index([status])
}

// Cola HITL del purificador (reemplaza JSON en data/raw_documents/review/).
model PurifierReview {
  reviewId    String   @id
  particula   String
  assetId     String?
  title       String
  processedAt DateTime
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([processedAt])
  @@index([assetId])
}

// Metadatos desacoplados del agente Meta-Meteador (vinculados por documentId).
model DocumentMeta {
  documentId    String   @id
  titulo        String
  tituloLocked  Boolean  @default(false)
  titleApplied  Boolean  @default(false)
  materia       String
  particula     String
  campo         String
  onda          String
  tiempoEspacio String
  posicion      String
  areas         Json
  processTrace  Json?
  modelUsed     String?
  processedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([processedAt])
}

// Marcadores de X (Twitter) — calibración Vibe 1-12 + enriquecimiento IA.
model XBookmark {
  id             String    @id @default(uuid())
  externalId     String?
  author         String
  handle         String
  text           String
  mediaUrls      Json      @default("[]")
  tweetUrl       String?
  bookmarkedAt   String?
  weight         Int?
  calibratedAt   DateTime?
  titleEs        String?
  metaTags       Json?
  linkedProjects Json?
  enrichedAt     DateTime?
  importBatchId  String?
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([weight])
  @@index([importBatchId])
  @@index([externalId])
}

// Enciclopedia generativa (Enciclopediador).
model EncyclopediaEntry {
  id              String   @id @default(uuid())
  slug            String   @unique
  title           String
  body            String
  explorableTerms Json
  parentEntryId   String?
  triggerTerm     String?
  model           String?
  validatedCount  Int      @default(0)
  reportCount     Int      @default(0)
  kgNodeId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent    EncyclopediaEntry?   @relation("ExplorationTree", fields: [parentEntryId], references: [id])
  children  EncyclopediaEntry[]  @relation("ExplorationTree")
  edgesFrom EncyclopediaEdge[]   @relation("EdgeFrom")
  edgesTo   EncyclopediaEdge[]   @relation("EdgeTo")
  reports   EncyclopediaReport[]

  @@index([parentEntryId])
  @@index([slug])
}

model EncyclopediaEdge {
  id          String   @id @default(uuid())
  fromEntryId String
  toEntryId   String
  triggerTerm String
  createdAt   DateTime @default(now())

  fromEntry EncyclopediaEntry @relation("EdgeFrom", fields: [fromEntryId], references: [id], onDelete: Cascade)
  toEntry   EncyclopediaEntry @relation("EdgeTo", fields: [toEntryId], references: [id], onDelete: Cascade)

  @@unique([fromEntryId, toEntryId, triggerTerm])
  @@index([fromEntryId])
  @@index([toEntryId])
}

model EncyclopediaReport {
  id           String   @id @default(uuid())
  entryId      String
  type         String
  comment      String?
  bodySnapshot String?
  createdAt    DateTime @default(now())

  entry EncyclopediaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([type])
}

// Ludus — Castillo: grids y tarjetas del canvas futurista.
model CastleGrid {
  id        String       @id @default(uuid())
  name      String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  cards     CastleCard[]
}

model CastleCard {
  id         String   @id @default(uuid())
  gridId     String
  sourceType String
  sourceId   String?
  title      String
  subtitle   String?
  accent     String?
  tags       Json     @default("[]")
  metadata   Json     @default("{}")
  layout     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  grid CastleGrid @relation(fields: [gridId], references: [id], onDelete: Cascade)

  @@unique([gridId, sourceType, sourceId])
  @@index([gridId])
  @@index([sourceType, sourceId])
}

// Ludus — gamificación: estado global, calibración, microtareas y asaltos.
model LudusState {
  id                 String   @id @default("singleton")
  signalPoints       Int      @default(0)
  unlockedStatues    Json     @default("[]")
  assaultStreakToday Int      @default(0)
  lastAssaultDate    String?
  updatedAt          DateTime @updatedAt
}

model LudusProjectRegistry {
  id               String    @id @default(uuid())
  projectId        String    @unique
  status           String    @default("active")
  lastCalibratedAt DateTime?
  updatedAt        DateTime  @updatedAt

  @@index([status])
}

model LudusMicrotask {
  id           String   @id @default(uuid())
  projectId    String
  title        String
  estimatedMin Int      @default(15)
  baseWeight   Int      @default(3)
  status       String   @default("pending")
  forgedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assaults LudusAssaultSession[]

  @@index([projectId])
  @@index([status])
}

model LudusAssaultSession {
  id            String    @id @default(uuid())
  microtaskId   String?
  pendingTaskId String?
  title         String
  durationMin   Int       @default(25)
  startedAt     DateTime
  endedAt       DateTime?
  completed     Boolean   @default(false)
  tabSurvived   Boolean   @default(false)
  signalPoints  Int       @default(0)

  microtask   LudusMicrotask? @relation(fields: [microtaskId], references: [id], onDelete: SetNull)
  pendingTask PendingTask?    @relation(fields: [pendingTaskId], references: [id], onDelete: SetNull)

  @@index([startedAt])
  @@index([microtaskId])
  @@index([pendingTaskId])
}

model MemoryEmbedding {
  id          String   @id @default(uuid())
  sourceType  String
  sourceId    String
  chunkIndex  Int      @default(0)
  title       String
  body        String
  contentHash String
  embedModel  String
  dimensions  Int
  embedding   String
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceType, sourceId, chunkIndex])
  @@index([sourceType, sourceId])
  @@index([contentHash])
}

// Ubicaciones geográficas — hitos permanentes y lugares temporales.
model GeoLocation {
  id          String   @id @default(uuid())
  name        String
  address     String?
  latitude    Float
  longitude   Float
  isPermanent Boolean  @default(false)
  source      String   @default("manual")
  placeId     String?
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPermanent])
  @@index([latitude, longitude])
}

// Mago 22 — colecciones indexadas 1–22 sobre la matriz hermética fija.
model MagoColeccion {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String   @default("")
  kind        String   @default("generic")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       MagoColeccionItem[]
}

model MagoColeccionItem {
  id          String @id @default(uuid())
  coleccionId String
  slot        Int
  titulo      String @default("")
  contenido   String @default("")
  refKind     String @default("none")
  refId       String?
  metadata    Json

  coleccion MagoColeccion @relation(fields: [coleccionId], references: [id], onDelete: Cascade)

  @@unique([coleccionId, slot])
  @@index([refKind, refId])
}

// Log unificado de actividad de la plataforma (pipelines, agentes, HITL).
model ActivityLog {
  id            String   @id @default(uuid())
  occurredAt    DateTime
  category      String
  action        String
  title         String
  summary       String?
  agentId       String?
  agentName     String?
  modelUsed     String?
  sourceType    String?
  sourceRef     String?
  correlationId String?
  metadata      Json
  createdAt     DateTime @default(now())

  @@unique([sourceType, sourceRef, action])
  @@index([occurredAt])
  @@index([category, occurredAt])
  @@index([agentId, occurredAt])
  @@index([correlationId])
}

// Ledger financiero — transacciones con flujo HITL (pending → confirmed).
model FinancialTransaction {
  id              String    @id @default(uuid())
  type            String
  amount          Float
  currency        String    @default("EUR")
  concept         String
  vendor          String?
  incomeCategory  String?
  expenseTier     String?
  projectLabel    String?
  status          String    @default("pending")
  sourceChannel   String
  sourceRaw       String?
  confidence      Float?
  occurredAt      DateTime
  isRecurring     Boolean   @default(false)
  isActive        Boolean   @default(true)
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, occurredAt])
  @@index([type, status])
  @@index([expenseTier, status])
  @@index([occurredAt])
}

// Capital económico del operador (singleton id = "operator").
model FinancialCapital {
  id        String   @id @default("operator")
  amount    Float    @default(0)
  currency  String   @default("EUR")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Señales HITL / RLHF local (ediciones humanas sobre nodos, aristas y campos UI).
model FeedbackSignal {
  id            String   @id @default(uuid())
  action        String
  polarity      String   @default("positive")
  targetKind    String
  targetId      String?
  fieldPath     String?
  previousValue String?
  nextValue     String?
  channel       String?
  metadata      Json
  createdAt     DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetKind, targetId])
  @@index([channel])
}
